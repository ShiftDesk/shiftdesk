rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── customers ─────────────────────────────────────────────────────────
    // Read is open — client-side password verification requires it.
    // Writes: only valid cust_<digits> IDs, mandatory fields, non-empty values.
    // Delete: only valid cust_<digits> IDs.
    match /customers/{id} {
      allow read: if true;
      allow write: if id.matches('cust_[0-9]+')
        && request.resource.data.keys().hasOnly([
          'id', 'name', 'contact', 'email', 'password', 'plan', 'duration',
          'startDate', 'expiryDate', 'status', 'notes',
          'hasPayroll', 'hasBudget', 'createdAt'
        ])
        && request.resource.data.keys().hasAll(['id', 'name', 'email', 'status'])
        && request.resource.data.email is string
        && request.resource.data.email.size() > 0
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0;
      allow delete: if id.matches('cust_[0-9]+');
    }

    // ── appSettings ───────────────────────────────────────────────────────
    // Only the admin password document is readable/writable.
    // Delete is permanently blocked.
    match /appSettings/{id} {
      allow read:  if id == 'shiftdesk_admin_pw';
      allow write: if id == 'shiftdesk_admin_pw'
        && request.resource.data.keys().hasOnly(['value'])
        && request.resource.data.value is string
        && request.resource.data.value.size() > 0;
      allow delete: if false;
    }

    // ── passwordResets ────────────────────────────────────────────────────
    // Read: open (admin panel needs to list them).
    // Create: customers can submit; email + requestedAt required, size-capped.
    // Update: never allowed.
    // Delete: only valid reset ID patterns (admin clearing handled requests).
    match /passwordResets/{id} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasOnly(['email', 'requestedAt', 'note'])
        && request.resource.data.email is string
        && request.resource.data.email.size() > 0
        && request.resource.data.email.size() < 256
        && request.resource.data.requestedAt is string;
      allow update: if false;
      allow delete: if id.matches('reset_[0-9]+')
        || id.matches('pr_[a-zA-Z0-9_]+');
    }

    // ── customerData ──────────────────────────────────────────────────────
    // shiftdesk.html builds keys as:
    //   'cust_' + customer.id + '_' + suffix
    // Since customer.id is already 'cust_<timestamp>', the real key is:
    //   'cust_cust_<timestamp>_<suffix>'
    //
    // admin.html builds manager password keys as:
    //   'mgr_pw_' + customer.id  →  'mgr_pw_cust_<timestamp>'
    //
    // Both patterns are listed below. The write rule also enforces that only
    // a single {value: ...} field is stored — no extra fields allowed.
    match /customerData/{id} {
      allow read: if
        id.matches('cust_(?:cust_)?[0-9]+_(staff|shifts|meetings|monthStore|monthMeet|avail|clockHistory|pi)')
        || id.matches('mgr_pw_(?:cust_)?[0-9]+');

      allow write: if (
          id.matches('cust_(?:cust_)?[0-9]+_(staff|shifts|meetings|monthStore|monthMeet|avail|clockHistory|pi)')
          || id.matches('mgr_pw_(?:cust_)?[0-9]+')
        )
        && request.resource.data.keys().hasOnly(['value']);

      allow delete: if
        id.matches('cust_(?:cust_)?[0-9]+_(staff|shifts|meetings|monthStore|monthMeet|avail|clockHistory|pi)')
        || id.matches('mgr_pw_(?:cust_)?[0-9]+');
    }

  }
}
